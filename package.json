{
  "name": "focus-mode",
  "version": "1.0.0",
  "description": "Block distracting websites and apps during focus sessions",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.radimzavadil.opal",
    "productName": "Opal",
    "icon": "assets/icon.ico",
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "jsdom": "^29.0.1"
  }
}